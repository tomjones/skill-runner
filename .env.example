# skill-runner defaults — all overridable via CLI flags
SKILL_MODEL=opus
SKILL_EFFORT=max
SKILL_MAX_TURNS=20
SKILL_ALLOWED_TOOLS="Bash,Read,Write,Glob,Grep"

# Parallel workers (--parallel or -j flag also works)
# SKILL_PARALLEL=3

# Rate limit thresholds (% utilization of 5-hour window)
# SKILL_THROTTLE_AT=85    # reduce to 1 worker at this %
# SKILL_PAUSE_AT=95       # stop launching entirely, wait for reset

# Mario sound effects (requires WSL2 + Windows Terminal)
# SKILL_SOUNDS=true
